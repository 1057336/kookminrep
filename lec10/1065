N=int(input())

def isHansu(num):
    if num<100:
        return 1
    
    oneN=str(num)
    diff=int(oneN[0])-int(oneN[1])
    
    for i in range(1,len(oneN)-1):
        if int(oneN[i])-int(oneN[i+1])!=diff:
            return False
    return 1

count=0
for i in range(1,N+1):
    if isHansu(i):
        count=count+1
print(count)
